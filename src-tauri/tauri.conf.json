{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LightMark",
  "version": "0.1.0",
  "identifier": "com.openclaw.lightmark",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npx vite build",
    "frontendDist": "../dist",
    "devUrlAllowlist": ["http://localhost:1420"]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LightMark",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    },
    "assetProtocol": {
      "scope": ["**"],
      "enable": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
